<Window x:Class="WindowsApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="Advanced Mirroring Core" Height="720" Width="1280"
        Background="#121212" WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1E1E1E" CornerRadius="0 15 15 0" Grid.Column="0" Padding="20">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="MirrorCast Pro" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" Margin="0,0,0,30"/>

                <Button Content="Conectar via USB" Command="{Binding ConnectUsbCommand}" Height="45" Background="#2962FF" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Button Content="Conectar via Wi-Fi" Command="{Binding ConnectWifiCommand}" Height="45" Background="#1E1E1E" BorderBrush="#333333" Foreground="White" Margin="0,0,0,10"/>
                
                <TextBlock Text="{Binding ConnectionStatus}" Foreground="#888888" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                
                <Separator Background="#333333" Margin="0,20,0,20"/>

                <TextBlock Text="Ajustes de Qualidade" Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                <ComboBox SelectedIndex="1" Background="#252525" Foreground="Black">
                    <ComboBoxItem Content="4K UltraHD (60 FPS)"/>
                    <ComboBoxItem Content="1080p FullHD (60 FPS)"/>
                    <ComboBoxItem Content="720p HD (30 FPS)"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#000000">
            <Image x:Name="StreamRenderer" 
                   Stretch="Uniform"
                   MouseDown="StreamRenderer_MouseDown"
                   MouseMove="StreamRenderer_MouseMove"
                   MouseUp="StreamRenderer_MouseUp"/>
        </Grid>
    </Grid>
</Window>
