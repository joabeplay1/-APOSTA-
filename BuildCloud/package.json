{
  "name": "buildcloud",
  "version": "1.0.0",
  "description": "IDE com compilação via GitHub Actions",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "electron:build": "tsc -p tsconfig.electron.json",
    "start": "electron ."
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "axios": "^1.7.0",
    "electron-store": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^37.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  }
}
